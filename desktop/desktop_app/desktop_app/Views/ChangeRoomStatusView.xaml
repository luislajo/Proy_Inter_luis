<UserControl x:Class="desktop_app.Views.ChangeRoomStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F6F0"
             Style="{StaticResource UserControlBase}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
    
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button DockPanel.Dock="Right"
                Content="Volver"
                Style="{StaticResource RedReturnBtn}"
                Command="{Binding BackCommand}"
                Margin="0,0,12,0"/>
                <Button Content="Guardar cambio"
                        Style="{StaticResource SaveBtn}"
                        Command="{Binding SaveCommand}"
                        MinWidth="140"/>
            </StackPanel>
            <TextBlock Text="Cambiar estado de habitación"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding TitleText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="0,0,0,14"/>

                <!-- Formulario -->
                <Border Grid.Row="1"
                        Background="#FFFFFF"
                        CornerRadius="14"
                        Padding="14"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                <Label Content="Estado" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource DropdownStyle}"
                                          ItemsSource="{Binding StatusOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedStatus, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Label Content="Duración" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource TextBoxForm}"
                                         Text="{Binding EstimatedMinutesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Opcional"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <Label Content="Motivo (obligatorio si no disponible)" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource TextBoxForm}"
                                     MinHeight="88"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Text="{Binding Reason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Historial -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Historial de estados"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <ListView ItemsSource="{Binding History}"
                              AlternationCount="2"
                              ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}"
                              BorderThickness="0.5"
                              MaxHeight="420">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Fecha" HeaderContainerStyle="{StaticResource TableHeader}" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ChangedAtText}" Style="{StaticResource GridViewCellText}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Cambio de estado" HeaderContainerStyle="{StaticResource TableHeader}" Width="340">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Margin="8,4">
                                                <Border Style="{StaticResource RoomStatusPillByCodeStyle}"
                                                        Tag="{Binding PreviousStatus}">
                                                    <TextBlock Text="{Binding PreviousStatusSpanish}"
                                                               Foreground="#ffffff"
                                                               Padding="10,4"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               FontSize="13"/>
                                                </Border>
                                                <TextBlock Text="→"
                                                           Margin="10,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="#374151"/>
                                                <Border Style="{StaticResource RoomStatusPillByCodeStyle}"
                                                        Tag="{Binding NewStatus}">
                                                    <TextBlock Text="{Binding NewStatusSpanish}"
                                                               Foreground="#ffffff"
                                                               Padding="10,4"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               FontSize="13"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Motivo" HeaderContainerStyle="{StaticResource TableHeader}" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ReasonDisplay}" Style="{StaticResource GridViewCellText}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Minutos" HeaderContainerStyle="{StaticResource TableHeader}" Width="72">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EstimatedMinutesDisplay}" Style="{StaticResource GridViewCellText}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
