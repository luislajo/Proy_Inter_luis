<UserControl x:Class="desktop_app.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1200"
             Style="{StaticResource UserControlBase}">

    <Grid Margin="22">
        <TabControl Background="#F8F6F0"
                    BorderThickness="0"
                    Foreground="#1f3b4d"
                    ItemContainerStyle="{StaticResource AppTabItem}">
            <TabItem Header="Habitaciones">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ================= HEADER ================= -->
                    <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Ventana de Habitaciones"
                                           Style="{StaticResource HeaderMainTitle}"/>
                                <Button DockPanel.Dock="Right"
                                        Content=" + Crear habitación"
                                        Style="{StaticResource HeaderNavigateButton}"
                                        Command="{Binding GoCreateRoomCommand}"/>
                            </DockPanel>

                            <Border Grid.Row="1"
                                    Background="#F7FAFD"
                                    CornerRadius="14"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,10,10">
                                        <Label Content="Tipo" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <ComboBox Style="{StaticResource DropdownStyle}"
                                                  SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Content">
                                            <ComboBoxItem Content="Todos"/>
                                            <ComboBoxItem Content="single"/>
                                            <ComboBoxItem Content="double"/>
                                            <ComboBoxItem Content="suite"/>
                                            <ComboBoxItem Content="family"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,10,10">
                                        <Label Content="Huéspedes" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding GuestsText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,10,10">
                                        <Label Content="Min (€)" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding MinPriceText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="0,0,10,10">
                                        <Label Content="Max (€)" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding MaxPriceText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Margin="0,0,0,10">
                                        <Label Content="Extras / Buscar" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <TextBox Style="{StaticResource TextBoxForm}" Text="{Binding ExtrasText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Busca por extras..."/>
                                    </StackPanel>

                                    <Grid Grid.Row="1" Grid.ColumnSpan="5" Margin="0,5,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <CheckBox Content="Solo disponibles" Style="{StaticResource FormCheckBox}" IsChecked="{Binding OnlyAvailable}" Margin="0,0,15,0"/>
                                            <CheckBox Content="Cama extra" Style="{StaticResource FormCheckBox}" IsChecked="{Binding HasExtraBed}" Margin="0,0,15,0"/>
                                            <CheckBox Content="Cuna" Style="{StaticResource FormCheckBox}" IsChecked="{Binding HasCrib}" Margin="0,0,15,0"/>
                                            <CheckBox Content="Oferta" Style="{StaticResource FormCheckBox}" IsChecked="{Binding HasOffer}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Style="{StaticResource ClearFiltersBtn}"
                                                    Content="Limpiar"
                                                    Command="{Binding ClearFiltersCommand}"
                                                    Height="38"
                                                    Padding="15,0"
                                                    Margin="0,0,10,0"
                                                    FontSize="14"/>
                                            <Button Style="{StaticResource SaveBtn}"
                                                    Content="Buscar"
                                                    Command="{Binding SearchCommand}"
                                                    Height="38"
                                                    Width="120"
                                                    Margin="0"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource SaveBtn}"
                                Content="Refrescar"
                                Command="{Binding RefreshCommand}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding Rooms}"
                                      ItemTemplate="{StaticResource RoomCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Tablero">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Ventana de Estados"
                                           Style="{StaticResource HeaderMainTitle}"/>
                            </DockPanel>

                            <Border Grid.Row="1"
                                    Background="#F7FAFD"
                                    CornerRadius="14"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <Label Content="Estado" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <ComboBox Style="{StaticResource DropdownStyle}"
                                                  ItemsSource="{Binding RoomStatusOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding BoardStatusFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                        <Label Content="Buscar (número o tipo)" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <TextBox Style="{StaticResource TextBoxForm}"
                                                 Text="{Binding BoardSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource SaveBtn}"
                                            Content="Refrescar"
                                            Command="{Binding LoadStatusBoardCommand}"
                                            VerticalAlignment="Bottom"
                                            Height="38"
                                            Width="120"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding BoardRoomsView.Count, StringFormat=Resultados: {0}}"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource SaveBtn}"
                                Content="Refrescar"
                                Command="{Binding LoadStatusBoardCommand}"/>
                    </Grid>

                    <!-- Tabla estilo Booking/Usuarios (ListView + GridView) -->
                    <ListView Grid.Row="2"
                              x:Name="BoardRoomsListView"
                              ItemsSource="{Binding BoardRoomsView}"
                              SelectedItem="{Binding SelectedBoardRoom, Mode=TwoWay}"
                              AlternationCount="2"
                              ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}"
                              SizeChanged="ListView_SizeChanged"
                              Margin="10 3"
                              BorderThickness="0.5">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Número" HeaderContainerStyle="{StaticResource TableHeader}" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RoomNumber}" Style="{StaticResource GridViewCellText}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Tipo" HeaderContainerStyle="{StaticResource TableHeader}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Type}" Style="{StaticResource GridViewCellText}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Estado" HeaderContainerStyle="{StaticResource TableHeader}" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource RoomStatusPillStyle}">
                                                <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource RoomStatusPillTextStyle}"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="" HeaderContainerStyle="{StaticResource TableHeader}" Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource UpdateBookingBtn}"
                                                    Content="edit"
                                                    Command="{Binding DataContext.OpenChangeStatusCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <TabItem Header="Incidencias">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Incidencias"
                                           Style="{StaticResource HeaderMainTitle}"/>
                                <TextBlock Text="{Binding IncidentSummaryText}"
                                           FontSize="12"
                                           Foreground="#D6EAF8"
                                           VerticalAlignment="Center"
                                           Margin="14,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Background="#F7FAFD"
                                    CornerRadius="14"
                                    Padding="12"
                                    Margin="0,14,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="1.4*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                        <Label Content="Severidad" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <ComboBox Style="{StaticResource DropdownStyle}"
                                                  ItemsSource="{Binding IncidentSeverityOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding IncidentSeverityFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,10">
                                        <Label Content="Estado" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <ComboBox Style="{StaticResource DropdownStyle}"
                                                  ItemsSource="{Binding IncidentStatusOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding IncidentStatusFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,10">
                                        <Label Content="Habitación" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <TextBox Style="{StaticResource TextBoxForm}"
                                                 Text="{Binding IncidentRoomFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,10">
                                        <Label Content="Rango de fechas" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal">
                                            <DatePicker Width="200"
                                                        Language="es-ES"
                                                        SelectedDate="{Binding IncidentFilterFromDate, Mode=TwoWay}"
                                                        Style="{StaticResource DatePickerForm}"/>
                                            <TextBlock Text=" - " VerticalAlignment="Center" Margin="4,0"/>
                                            <DatePicker Width="200"
                                                        Language="es-ES"
                                                        SelectedDate="{Binding IncidentFilterToDate, Mode=TwoWay}"
                                                        Style="{StaticResource DatePickerForm}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.ColumnSpan="4"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Style="{StaticResource ClearFiltersBtn}"
                                                Content="Limpiar"
                                                Command="{Binding ClearIncidentFiltersCommand}"
                                                Height="38"
                                                Padding="15,0"
                                                Margin="0,0,10,0"
                                                FontSize="14"/>
                                        <Button Style="{StaticResource SaveBtn}"
                                                Content="Buscar"
                                                Command="{Binding LoadIncidentsCommand}"
                                                Height="38"
                                                Width="120"
                                                FontSize="14"
                                                FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Listado -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding IncidentsStatusText}"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Style="{StaticResource SaveBtn}"
                                        Content="Refrescar"
                                        Command="{Binding LoadIncidentsCommand}"/>
                            </Grid>

                            <!-- Tabla estilo Booking/Usuarios (ListView + GridView) -->
                            <ListView Grid.Row="1"
                                      x:Name="IncidentsListView"
                                      ItemsSource="{Binding Incidents}"
                                      SelectedItem="{Binding SelectedIncident, Mode=TwoWay}"
                                      AlternationCount="2"
                                      ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}"
                                      SizeChanged="ListView_SizeChanged"
                                      Margin="10 3"
                                      BorderThickness="0.5">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Fecha" HeaderContainerStyle="{StaticResource TableHeader}" Width="135">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ReportedAt, StringFormat='dd/MM/yyyy HH:mm'}" Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Habitación" HeaderContainerStyle="{StaticResource TableHeader}" Width="110">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding RoomNumber}" Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Severidad" HeaderContainerStyle="{StaticResource TableHeader}" Width="100">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SeverityLabel}" Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Estado" HeaderContainerStyle="{StaticResource TableHeader}" Width="110">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource StatusTextStyle}"
                                                            ToolTipService.InitialShowDelay="200"
                                                            ToolTipService.ShowDuration="60000"
                                                            Cursor="Help">
                                                        <Border.ToolTip>
                                                            <ToolTip MaxWidth="360">
                                                                <TextBlock Text="{Binding Description}"
                                                                           TextWrapping="Wrap"/>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   Style="{StaticResource GridViewCellText}"
                                                                   Foreground="#ffffff"/>
                                                    </Border>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Tipo" HeaderContainerStyle="{StaticResource TableHeader}" Width="110">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Type}" Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Asignado a" HeaderContainerStyle="{StaticResource TableHeader}">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding AssignedToDisplay}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Style="{StaticResource GridViewCellText}"
                                                               ToolTip="{Binding AssignedToDisplay}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="" HeaderContainerStyle="{StaticResource TableHeader}" Width="65">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource UpdateBookingBtn}"
                                                            Content="edit"
                                                            Command="{Binding DataContext.OpenIncidentDetailCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
