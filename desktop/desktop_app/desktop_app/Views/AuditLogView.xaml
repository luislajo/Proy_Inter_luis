<UserControl x:Class="desktop_app.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:desktop_app.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             Style="{StaticResource UserControlBase}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <viewmodels:AuditLogViewModel/>
    </UserControl.DataContext>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Historial de Auditoría"
                               Style="{StaticResource HeaderMainTitle}"/>
                </DockPanel>

                <!-- Filtros -->
                <Border Grid.Row="1"
                        Background="#F7FAFD"
                        CornerRadius="14"
                        Padding="12"
                        Margin="0,14,0,0">
                    <DockPanel LastChildFill="False">
                        <!-- Botón buscar -->
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource SaveBtn}" Content="Buscar"
                                Command="{Binding SearchCommand}"
                                Height="38" Width="120" FontSize="14" FontWeight="SemiBold"
                                VerticalAlignment="Bottom"/>

                        <!-- Filtro acción -->
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0">
                            <Label Content="Acción" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource DropdownStyle}"
                                      Width="160"
                                      ItemsSource="{Binding FilterOptions}"
                                      SelectedItem="{Binding SelectedFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Filtro colección -->
                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                            <Label Content="Colección" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource DropdownStyle}"
                                      Width="160"
                                      ItemsSource="{Binding FilterCollectionOptions}"
                                      SelectedItem="{Binding SelectedCollectionFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== Status + Refrescar ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding StatusText}"
                       Foreground="#6B7280"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Style="{StaticResource SaveBtn}"
                    Content="Refrescar"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- ===== LOADING ===== -->
        <TextBlock Grid.Row="2" Text="Cargando historial..."
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                   HorizontalAlignment="Center" VerticalAlignment="Top"
                   Margin="0,10,0,0" Foreground="#6B7280" FontSize="14"/>

        <!-- ===== TABLA (ListView + GridView) ===== -->
        <ListView Grid.Row="2" 
                  ItemsSource="{Binding Logs}" 
                  SizeChanged="ListView_SizeChanged"
                  AlternationCount="2" 
                  ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}" 
                  Margin="0,5,0,0" 
                  BorderThickness="0.5">
            <ListView.View>
                <GridView>
                    <!-- Fecha -->
                    <GridViewColumn Header="Fecha" HeaderContainerStyle="{StaticResource TableHeader}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Timestamp, StringFormat='dd/MM/yyyy HH:mm'}" 
                                           Style="{StaticResource GridViewCellText}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Acción -->
                    <GridViewColumn Header="Acción" HeaderContainerStyle="{StaticResource TableHeader}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource AuditActionStyle}" HorizontalAlignment="Center" Padding="8,3">
                                    <TextBlock Text="{Binding Action}" Style="{StaticResource GridViewCellText}" Foreground="#ffffff" Padding="0"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Tipo de entidad -->
                    <GridViewColumn Header="Entidad" HeaderContainerStyle="{StaticResource TableHeader}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding EntityType}" 
                                           Style="{StaticResource GridViewCellText}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- ID Entidad -->
                    <GridViewColumn Header="ID" HeaderContainerStyle="{StaticResource TableHeader}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding EntityId}" 
                                           Style="{StaticResource GridViewCellText}"
                                           ToolTip="{Binding EntityId}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Resumen -->
                    <GridViewColumn Header="Resumen" HeaderContainerStyle="{StaticResource TableHeader}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SummaryText}" 
                                           Style="{StaticResource GridViewCellText}"
                                           ToolTip="{Binding TooltipText}"
                                           ToolTipService.InitialShowDelay="100"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Actor -->
                    <GridViewColumn Header="Actor" HeaderContainerStyle="{StaticResource TableHeader}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActorType}" 
                                           Style="{StaticResource GridViewCellText}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
