<UserControl x:Class="desktop_app.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:desktop_app.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Style="{StaticResource UserControlBase}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <viewmodels:AuditLogViewModel/>
    </UserControl.DataContext>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER (idéntico a RoomView) ================= -->
        <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Historial de Auditoría"
                               Style="{StaticResource HeaderMainTitle}"/>
                </DockPanel>

                <!-- Card blanca de filtros (mismo estilo que RoomView) -->
                <Border Grid.Row="1"
                        Background="#F7FAFD"
                        CornerRadius="14"
                        Padding="12"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Fila 0: Input del filtro -->
                        <StackPanel Margin="0,0,0,10">
                            <Label Content="Acción" Style="{StaticResource LabelForm}" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource DropdownStyle}"
                                      Width="180"
                                      HorizontalAlignment="Left"
                                      ItemsSource="{Binding FilterOptions}"
                                      SelectedItem="{Binding SelectedFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Fila 1: Botones a la derecha -->
                        <Grid Grid.Row="1" Margin="0,5,0,5">
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button Style="{StaticResource ClearFiltersBtn}" Content="Limpiar"
                                        Command="{Binding ClearFiltersCommand}"
                                        Height="38" Padding="15,0" Margin="0,0,10,0" FontSize="14"/>
                                <Button Style="{StaticResource SaveBtn}" Content="Buscar"
                                        Command="{Binding SearchCommand}"
                                        Height="38" Width="120" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== Status + Refrescar (mismo estilo que RoomView) ===== -->
        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding StatusText}"
                       Foreground="#6B7280"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Style="{StaticResource SaveBtn}"
                    Content="Refrescar"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- ===== LOADING ===== -->
        <TextBlock Grid.Row="2" Text="Cargando historial..."
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                   HorizontalAlignment="Center" VerticalAlignment="Top"
                   Margin="0,10,0,0" Foreground="#6B7280" FontSize="14"/>

        <!-- ===== TIMELINE LIST ===== -->
        <ScrollViewer Grid.Row="2" Margin="0,5,0,0">
            <ItemsControl ItemsSource="{Binding Logs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Fecha -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,5,0">
                                <TextBlock Text="{Binding Timestamp, StringFormat='dd/MM/yyyy'}"
                                           FontWeight="Bold" FontSize="11" Foreground="#4B5563" TextAlignment="Right"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}"
                                           FontSize="11" Foreground="#6B7280" TextAlignment="Right"/>
                            </StackPanel>

                            <!-- Línea de tiempo -->
                            <Grid Grid.Column="1" HorizontalAlignment="Center">
                                <Rectangle Width="2" Fill="#D1D5DB" Margin="0,22,0,0"
                                           HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
                                <Ellipse Width="14" Height="14" Fill="#004A8F" Stroke="White"
                                         StrokeThickness="2" VerticalAlignment="Top" Margin="0,6,0,0"/>
                            </Grid>

                            <!-- Card del log -->
                            <Border Grid.Column="2" Background="White" CornerRadius="10"
                                    Padding="16" Margin="8,0,0,0"
                                    BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <!-- Acción + Entidad -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border CornerRadius="4" Background="#EAF3FD" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Action}" FontWeight="SemiBold"
                                                       Foreground="#004A8F" FontSize="12"/>
                                        </Border>
                                        <TextBlock Text="{Binding EntityType}" FontWeight="SemiBold"
                                                   FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Resumen de cambios -->
                                    <TextBlock Text="{Binding DifferencesSummary}" TextWrapping="Wrap"
                                               Margin="0,2,0,6" FontSize="13" Foreground="#374151"/>

                                    <!-- Actor -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Actor:" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="#9CA3AF" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding ActorType}" FontSize="11" Foreground="#6B7280"/>
                                        <TextBlock Text=" (" FontSize="11" Foreground="#6B7280"/>
                                        <TextBlock Text="{Binding ActorId}" FontSize="11" Foreground="#6B7280"/>
                                        <TextBlock Text=")" FontSize="11" Foreground="#6B7280"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
