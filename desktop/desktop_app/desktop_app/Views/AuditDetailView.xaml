<UserControl x:Class="desktop_app.Views.AuditDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F6F0"
             Style="{StaticResource UserControlBase}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabecera -->
        <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <Button DockPanel.Dock="Right"
                            Content="Volver"
                            Style="{StaticResource RedReturnBtn}"
                            Command="{Binding BackCommand}"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Detalle de auditoría"
                               Style="{StaticResource HeaderMainTitle}"/>
                </DockPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,14,0,0">
                    <Border Style="{StaticResource AuditActionStyle}" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock Text="{Binding Action, Mode=OneWay}" FontSize="13" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Action}" Value="UPDATE">
                                            <Setter Property="Foreground" Value="#1f3b4d"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Border Style="{StaticResource IdWrapper}" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource UpdateIdStyle}"
                                   Text="{Binding EntityType, Mode=OneWay, StringFormat='Entidad: {0}'}"/>
                    </Border>

                    <Border Style="{StaticResource IdWrapper}" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource UpdateIdStyle}"
                                   Text="{Binding TimestampText, Mode=OneWay, StringFormat='Fecha: {0}'}"/>
                    </Border>

                    <Border Style="{StaticResource IdWrapper}" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource UpdateIdStyle}"
                                   Text="{Binding ActorType, Mode=OneWay, StringFormat='Actor: {0}'}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="#FFFFFF"
                    CornerRadius="14"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Estado anterior y nuevo"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"/>
                        <TextBlock Text="{Binding SummaryText, Mode=OneWay}"
                                   Foreground="#6B7280"
                                   Margin="0,4,0,0"/>
              
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Text="{Binding EmptyMessage, Mode=OneWay}"
                               Foreground="#6B7280"
                               FontSize="14"
                               Margin="0,20"
                               HorizontalAlignment="Center"
                               Visibility="{Binding ShowEmpty, Converter={StaticResource BoolToVis}}"/>

                    <ListView Grid.Row="2"
                              
                              x:Name="ComparisonListView"
                              ItemsSource="{Binding Fields}"
                              SizeChanged="ListView_SizeChanged"
                              AlternationCount="2"
                              BorderThickness="0.5"
                              MinHeight="280"
                              Margin="0,10,0,0"
                              Visibility="{Binding HasFields, Converter={StaticResource BoolToVis}}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Campo" HeaderContainerStyle="{StaticResource TableHeader}" Width="160">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FieldLabel}"
                                                       FontWeight="SemiBold"
                                                       Style="{StaticResource GridViewCellText}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Estado anterior" HeaderContainerStyle="{StaticResource TableHeader}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PreviousDisplay}"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridViewCellText}">
                                                        <Setter Property="Foreground" Value="#6B7280"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                                                <Setter Property="Foreground" Value="#dc3545"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Estado nuevo" HeaderContainerStyle="{StaticResource TableHeader}">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NewDisplay}"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridViewCellText}">
                                                        <Setter Property="Foreground" Value="#1F2937"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                                                <Setter Property="Foreground" Value="#047857"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource AlternatingListViewItemStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChanged}" Value="True">
                                        <Setter Property="Background" Value="#FFFBEB"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
