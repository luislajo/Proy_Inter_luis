<UserControl x:Class="desktop_app.Views.IncidentDetailWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F6F0"
             Style="{StaticResource UserControlBase}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderWrapper}" Margin="0,0,0,14">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Marcar resuelta"
                            Style="{StaticResource SaveBtn}"
                            Command="{Binding ResolveCommand}"
                            Margin="0,0,10,0"
                            MinWidth="140"
                            VerticalAlignment="Center"/>
                    <Button Content="Volver"
                            Style="{StaticResource RedReturnBtn}"
                            Command="{Binding BackCommand}"
                            VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Detalle de incidencia"
                               Style="{StaticResource HeaderMainTitle}"/>
                    <TextBlock Text="{Binding HeaderText}"
                               Foreground="#D6EAF8"
                               FontSize="13"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Descripción + empleado + notas (mismo border) -->
                <Border Background="#FFFFFF" CornerRadius="14" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Descripción"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="#1F2937"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding Incident.Description}"
                                   TextWrapping="Wrap"
                                   Foreground="#374151"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Empleado asignado"
                                           FontWeight="SemiBold" FontSize="15" Foreground="#1F2937" VerticalAlignment="Bottom"
                                           Margin="0,0,0,14"/>
                      
                            </StackPanel>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="Notas internas"
                                       FontWeight="SemiBold" FontSize="15" Foreground="#1F2937"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,0,14"/>

                            <ComboBox Grid.Row="1" Grid.Column="0"
                                      Style="{StaticResource DropdownStyle}"
                                      VerticalAlignment="Top"
                                      ItemsSource="{Binding AvailableEmployees}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding SelectedEmployeeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBox Grid.Row="1" Grid.Column="2"
                                     Style="{StaticResource TextBoxForm}"
                                     Text="{Binding NewInternalNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     MinHeight="56"
                                     VerticalAlignment="Top"/>

                            <Button Grid.Row="2" Grid.Column="0"
                                    Style="{StaticResource SaveBtn}"
                                    Content="Asignar"
                                    Command="{Binding AssignCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Height="38"
                                    MinWidth="110"
                                    FontSize="14"/>
                            <Button Grid.Row="2" Grid.Column="2"
                                    Style="{StaticResource SaveBtn}"
                                    Content="Añadir nota"
                                    Command="{Binding AddNoteCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Height="38"
                                    MinWidth="120"
                                    FontSize="14"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Historiales -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="14" Padding="14" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Historial de la incidencia"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="#1F2937"
                                       Margin="0,0,0,8"/>
                            <ListView x:Name="IncidentHistoryListView"
                                      ItemsSource="{Binding Incident.History}"
                                      SizeChanged="ListView_SizeChanged"
                                      AlternationCount="2"
                                      MinHeight="220"
                                      ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}"
                                      BorderThickness="0.5">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Fecha" HeaderContainerStyle="{StaticResource TableHeader}" Width="130">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding At, StringFormat='dd/MM/yyyy HH:mm'}"
                                                               Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Acción" HeaderContainerStyle="{StaticResource TableHeader}" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Action}" Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Usuario" HeaderContainerStyle="{StaticResource TableHeader}">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ByLabel}" Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="14" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Historial de notas"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       Foreground="#1F2937"
                                       Margin="0,0,0,8"/>
                            <ListView x:Name="IncidentNotesListView"
                                      ItemsSource="{Binding Incident.InternalNotes}"
                                      SizeChanged="ListView_SizeChanged"
                                      AlternationCount="2"
                                      MinHeight="220"
                                      ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}"
                                      BorderThickness="0.5">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Fecha" HeaderContainerStyle="{StaticResource TableHeader}" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}"
                                                               Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Autor" HeaderContainerStyle="{StaticResource TableHeader}" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding AuthorLabel}" Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Nota" HeaderContainerStyle="{StaticResource TableHeader}">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Note}"
                                                               TextWrapping="Wrap"
                                                               Style="{StaticResource GridViewCellText}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
